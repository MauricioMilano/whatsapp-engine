# Server
PORT=3000

# WhatsApp Credentials
VERIFY_TOKEN=your_verify_token_here
ACCESS_TOKEN=your_facebook_access_token_here
PHONE_NUMBER_ID=your_phone_number_id

# Optional - App Secret (for signature verification)
APP_SECRET=your_app_secret_here

# PostgreSQL Configuration (for NLP dialogue context persistence)
DATABASE_URL=postgresql://botuser:botpass123@localhost:5432/whatsapp_bot

# NLP Dialogue Engine
ENABLE_NLP_DIALOGUE=true
DIALOGUE_PATH=./dialogue.json
SESSION_TIMEOUT_MS=1800000
FALLBACK_SCORE_THRESHOLD=0.7